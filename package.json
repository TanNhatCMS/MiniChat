{
  "name": "minichat",
  "version": "1.0.0",
  "description": "MiniChat - Ứng dụng Chat Thời gian thực",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --parallel run build",
    "start": "pm2 start ecosystem.config.js",
    "stop": "pm2 stop ecosystem.config.js",
    "restart": "pm2 restart ecosystem.config.js",
    "delete": "pm2 delete ecosystem.config.js",
    "logs": "pm2 logs",
    "status": "pm2 status",
    "dev:server": "pnpm --filter minichat-server dev",
    "dev:client": "pnpm --filter minichat-client dev",
    "dev": "pnpm -r --parallel run dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --parallel run typecheck",
    "test": "pnpm -r --parallel run test",
    "test:server": "pnpm --filter minichat-server test",
    "test:client": "pnpm --filter minichat-client test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.4.0",
    "pm2": "^5.4.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
